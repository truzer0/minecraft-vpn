{
  "log": {
    "loglevel": "warning",
    "access": "/var/log/xray/access.log",
    "error": "/var/log/xray/error.log"
  },
  "dns": {
    "servers": [
      {
        "address": "https://dns.adguard.com/dns-query",
        "domains": [
          "geosite:category-ads-all"
        ]
      },
      {
        "address": "https://dns.google/dns-query",
        "domains": [
          "geosite:ru",
          "domain:yandex.ru",
          "domain:mail.ru",
          "domain:vk.com",
          "domain:sberbank.ru",
          "domain:gosuslugi.ru"
        ],
        "expectIPs": [
          "geoip:ru"
        ]
      },
      {
        "address": "1.1.1.1",
        "domains": [
          "geosite:discord",
          "geosite:telegram",
          "geosite:openai",
          "geosite:google",
          "geosite:youtube"
        ]
      },
      "8.8.8.8"
    ],
    "routing": {
      "rules": [
        {
          "type": "field",
          "domain": [
            "geosite:ru"
          ],
          "outboundTag": "direct"
        }
      ]
    }
  },
  "inbounds": [
    {
      "tag": "vless-in",
      "port": 8443,
      "protocol": "vless",
      "settings": {
        "clients": [],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "tcp",
        "security": "reality",
        "realitySettings": {
          "show": false,
          "dest": "discord.com:443",
          "xver": 0,
          "serverNames": [
            "discord.com",
            "cdn.discordapp.com"
          ],
          "privateKey": "YOUR_PRIVATE_KEY",
          "shortIds": ["", "6ba85179e30d4fc2"]
        }
      },
      "sniffing": {
        "enabled": true,
        "destOverride": ["http", "tls"]
      }
    },
    {
      "tag": "socks-in",
      "port": 1080,
      "protocol": "socks",
      "settings": {
        "auth": "noauth",
        "udp": true,
        "userLevel": 0
      },
      "sniffing": {
        "enabled": true,
        "destOverride": ["http", "tls"]
      }
    }
  ],
  "outbounds": [
    {
      "tag": "direct",
      "protocol": "freedom",
      "settings": {
        "domainStrategy": "UseIP"
      }
    },
    {
      "tag": "russia-proxy",
      "protocol": "vless",
      "settings": {
        "vnext": [
          {
            "address": "RU_SERVER_IP",
            "port": 8443,
            "users": [
              {
                "id": "USER_UUID",
                "encryption": "none",
                "flow": "xtls-rprx-vision"
              }
            ]
          }
        ]
      },
      "streamSettings": {
        "network": "tcp",
        "security": "reality",
        "realitySettings": {
          "serverName": "ya.ru",
          "fingerprint": "chrome",
          "publicKey": "RU_SERVER_PUBLIC_KEY",
          "shortId": "6ba85179e30d4fc2"
        }
      }
    },
    {
      "tag": "europe-proxy",
      "protocol": "vless",
      "settings": {
        "vnext": [
          {
            "address": "EU_SERVER_IP",
            "port": 8443,
            "users": [
              {
                "id": "USER_UUID",
                "encryption": "none",
                "flow": "xtls-rprx-vision"
              }
            ]
          }
        ]
      },
      "streamSettings": {
        "network": "tcp",
        "security": "reality",
        "realitySettings": {
          "serverName": "google.com",
          "fingerprint": "chrome",
          "publicKey": "EU_SERVER_PUBLIC_KEY",
          "shortId": "6ba85179e30d4fc2"
        }
      }
    },
    {
      "tag": "zapret-out",
      "protocol": "freedom",
      "settings": {
        "domainStrategy": "UseIP"
      },
      "streamSettings": {
        "sockopt": {
          "mark": 255,
          "tcpFastOpen": true,
          "tcpWindowClamp": 512
        }
      },
      "proxySettings": {
        "tag": "socks-in"
      }
    },
    {
      "tag": "block",
      "protocol": "blackhole",
      "settings": {}
    }
  ],
  "routing": {
    "domainStrategy": "IPIfNonMatch",
    "rules": [
      {
        "type": "field",
        "outboundTag": "block",
        "domain": [
          "geosite:category-ads-all"
        ]
      },
      {
        "type": "field",
        "outboundTag": "direct",
        "domain": [
          "geosite:ru",
          "domain:yandex.ru",
          "domain:mail.ru",
          "domain:vk.com",
          "domain:sberbank.ru",
          "domain:gosuslugi.ru",
          "domain:1c.ru",
          "domain:sbp.ru"
        ]
      },
      {
        "type": "field",
        "outboundTag": "zapret-out",
        "domain": [
          "geosite:telegram",
          "geosite:discord",
          "domain:yt3.ggpht.com",
          "domain:googlevideo.com",
          "domain:video.google.com"
        ]
      },
      {
        "type": "field",
        "outboundTag": "russia-proxy",
        "domain": [
          "domain:*.russia-only.com",
          "domain:*.government.ru"
        ]
      },
      {
        "type": "field",
        "outboundTag": "europe-proxy",
        "domain": [
          "geosite:google",
          "geosite:youtube",
          "geosite:github",
          "geosite:twitter",
          "geosite:instagram",
          "geosite:facebook",
          "geosite:openai"
        ]
      },
      {
        "type": "field",
        "outboundTag": "direct",
        "ip": [
          "geoip:ru",
          "geoip:private"
        ]
      },
      {
        "type": "field",
        "outboundTag": "direct",
        "protocol": ["bittorrent"]
      },
      {
        "type": "field",
        "port": "443,8443,25565-25585,27015-27050",
        "outboundTag": "direct",
        "network": "tcp,udp"
      },
      {
        "type": "field",
        "outboundTag": "europe-proxy",
        "network": "tcp,udp"
      }
    ]
  }
}